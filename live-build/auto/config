#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd -P)"
BUILD_ROOT="$PROJECT_ROOT/build"

# Reject a symlinked build root; all removal logic depends on physical paths.
if [ -L "$BUILD_ROOT" ]; then
    echo "ERROR: Build root is a symlink: $BUILD_ROOT" >&2
    exit 1
fi

mkdir -p "$BUILD_ROOT"
RESOLVED_BUILD_ROOT="$(cd "$BUILD_ROOT" && pwd -P)"
EXPECTED_BUILD_ROOT="$PROJECT_ROOT/build"

if [ "$RESOLVED_BUILD_ROOT" != "$EXPECTED_BUILD_ROOT" ]; then
    echo "ERROR: Build root resolves to $RESOLVED_BUILD_ROOT, expected $EXPECTED_BUILD_ROOT" >&2
    exit 1
fi

BUILD_DIR="$RESOLVED_BUILD_ROOT/live-build"

# Remove any previous build directory with safety checks.
if [ -e "$BUILD_DIR" ]; then
    TARGET="$(cd "$BUILD_DIR" && pwd -P)"
    EXPECTED="$BUILD_DIR"
    if [ "$TARGET" != "$EXPECTED" ]; then
        echo "ERROR: Build directory resolves to $TARGET, expected $EXPECTED" >&2
        exit 1
    fi
    rm -rf -- "$TARGET"
fi

mkdir -p "$BUILD_DIR/config"
mkdir -p "$BUILD_DIR/auto"

# Copy only Git-tracked source files.  Test imports can leave ignored Python
# bytecode under includes.chroot; copying the whole directory would place that
# bytecode in the next ISO.
copy_tracked_tree() {
    local source_tree="$1"
    local destination_tree="$2"
    local source_file relative destination

    while IFS= read -r -d '' source_file; do
        [ ! -L "$PROJECT_ROOT/$source_file" ] || {
            echo "ERROR: tracked build source must not be a symlink: $source_file" >&2
            exit 1
        }
        relative="${source_file#"$source_tree/"}"
        destination="$destination_tree/$relative"
        mkdir -p "$(dirname "$destination")"
        cp -p -- "$PROJECT_ROOT/$source_file" "$destination"
    done < <(git -C "$PROJECT_ROOT" ls-files -z -- "$source_tree")
}

copy_tracked_tree "live-build/config" "$BUILD_DIR/config"
copy_tracked_tree "live-build/auto" "$BUILD_DIR/auto"

# Conditionally stage local Wi-Fi credentials into the build tree.
# The file is NOT copied to the tracked source tree.
WIFI_SOURCE="$PROJECT_ROOT/local/wifi.nmconnection"
WIFI_DEST="$BUILD_DIR/config/includes.chroot/etc/NetworkManager/system-connections/sushida-os-wifi.nmconnection"

if [ -e "$WIFI_SOURCE" ]; then
    if [ -L "$WIFI_SOURCE" ]; then
        echo "ERROR: Wi-Fi credential file is a symlink: $WIFI_SOURCE" >&2
        exit 1
    fi
    if [ ! -f "$WIFI_SOURCE" ]; then
        echo "ERROR: Wi-Fi credential path is not a regular file: $WIFI_SOURCE" >&2
        exit 1
    fi
    mkdir -p "$(dirname "$WIFI_DEST")"
    install -m 0600 "$WIFI_SOURCE" "$WIFI_DEST"
fi

cd "$BUILD_DIR"
# Default kernel command line for the generated boot entries (BIOS and
# UEFI).  The VGA console stays quiet; systemd status lines go to the
# serial console (last console= owns /dev/console), which QEMU boot
# evidence and headless diagnosis rely on.  Real hardware without a
# serial port is unaffected.
BOOTAPPEND_LIVE="boot=live components quiet splash console=tty0 console=ttyS0,115200n8 systemd.show_status=true"

lb config noauto \
    --distribution trixie \
    --architectures amd64 \
    --binary-images iso-hybrid \
    --bootappend-live "$BOOTAPPEND_LIVE" \
    --source false \
    --apt-recommends false \
    --firmware-binary false \
    --firmware-chroot false \
    --archive-areas "main contrib non-free-firmware" \
    "$@"

# Mark configuration as complete.
touch "$BUILD_DIR/.configured"
