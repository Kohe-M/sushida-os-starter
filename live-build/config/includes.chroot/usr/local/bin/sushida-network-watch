#!/usr/bin/env bash
# Restart the managed kiosk session when its selected route no longer matches
# NetworkManager. Disconnected state selects the constrained local setup UI.
set -euo pipefail

readonly PROD_CONFIG="/etc/sushida-os/config.env"
readonly PROD_RUNTIME="/run/sushida-os"
readonly MIN_INTERVAL=30
readonly MAX_INTERVAL=3600

CONFIG_FILE="${SUSHIDA_OS_CONFIG:-$PROD_CONFIG}"
RUNTIME_DIR="${SUSHIDA_OS_RUNTIME:-$PROD_RUNTIME}"
MAX_ITER="${SUSHIDA_OS_MAX_ITERATIONS:-0}"
TEST_CGROUP_FILE="${SUSHIDA_OS_TEST_CGROUP_FILE:-}"
FORCE_OFFLINE=false

if [ "$CONFIG_FILE" != "$PROD_CONFIG" ] && [ "${SUSHIDA_OS_TEST_MODE:-0}" != "1" ]; then
    echo "ERROR: CONFIG_FILE override requires SUSHIDA_OS_TEST_MODE=1" >&2; exit 1
fi
if [ "$RUNTIME_DIR" != "$PROD_RUNTIME" ] && [ "${SUSHIDA_OS_TEST_MODE:-0}" != "1" ]; then
    echo "ERROR: RUNTIME_DIR override requires SUSHIDA_OS_TEST_MODE=1" >&2; exit 1
fi
if [ "$MAX_ITER" != "0" ] && [ "${SUSHIDA_OS_TEST_MODE:-0}" != "1" ]; then
    echo "ERROR: SUSHIDA_OS_MAX_ITERATIONS override requires SUSHIDA_OS_TEST_MODE=1" >&2; exit 1
fi
if [ -n "$TEST_CGROUP_FILE" ] && [ "${SUSHIDA_OS_TEST_MODE:-0}" != "1" ]; then
    echo "ERROR: SUSHIDA_OS_TEST_CGROUP_FILE requires SUSHIDA_OS_TEST_MODE=1" >&2; exit 1
fi
WIFI_CONNECTION_MARKER="${SUSHIDA_OS_WIFI_MARKER:-/run/sushida-wifi-status/connection-in-progress}"
if [ "$WIFI_CONNECTION_MARKER" != "/run/sushida-wifi-status/connection-in-progress" ] && \
   [ "${SUSHIDA_OS_TEST_MODE:-0}" != "1" ]; then
    echo "ERROR: SUSHIDA_OS_WIFI_MARKER override requires SUSHIDA_OS_TEST_MODE=1" >&2; exit 1
fi
case "${SUSHIDA_QEMU_FORCE_OFFLINE:-0}" in
    0) ;;
    1)
        if [ "${WLR_RENDERER:-}" != pixman ] || \
           [ "${WLR_RENDERER_ALLOW_SOFTWARE:-0}" != 1 ]; then
            echo "ERROR: QEMU force-offline requires all QEMU renderer markers" >&2
            exit 1
        fi
        FORCE_OFFLINE=true ;;
    *) echo "ERROR: Invalid SUSHIDA_QEMU_FORCE_OFFLINE value" >&2; exit 1 ;;
esac
# Resolve the shared route model and signal helper relative to this script
# so the same paths work from the repository checkout and from the image
# (/usr/local/bin -> /usr/lib/python3/dist-packages, /usr/local/libexec).
SELF_DIR="$(dirname "$(readlink -f "$0")")"
readonly SELF_DIR
readonly RUNTIME_LIB="$SELF_DIR/../../lib/python3/dist-packages"
readonly KIOSK_SIGNAL="$SELF_DIR/../libexec/sushida-kiosk-signal"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "ERROR: Config file not found: $CONFIG_FILE" >&2; exit 1
fi
SUSHIDA_URL=""; INTERVAL=30; seen_url=false; seen_interval=false
while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [ -z "$line" ] || [[ "$line" == "#"* ]]; then continue; fi
    if [[ "$line" != *"="* ]]; then
        echo "ERROR: Invalid config line (missing '='): $line" >&2; exit 1
    fi
    key="${line%%=*}"; value="${line#*=}"
    case "$key" in
        SUSHIDA_URL)
            if $seen_url; then echo "ERROR: Duplicate SUSHIDA_URL" >&2; exit 1; fi
            seen_url=true; SUSHIDA_URL="$value" ;;
        NETWORK_CHECK_INTERVAL_SECONDS)
            if $seen_interval; then
                echo "ERROR: Duplicate NETWORK_CHECK_INTERVAL_SECONDS" >&2; exit 1
            fi
            seen_interval=true; INTERVAL="$value" ;;
        NETWORK_SETUP_GRACE_SECONDS) ;;
        AUDIO_VOLUME_PERCENT) ;;
        SCREEN_BRIGHTNESS_PERCENT) ;;
        *) echo "ERROR: Unknown config key: $key" >&2; exit 1 ;;
    esac
done < "$CONFIG_FILE"

if [ -z "$SUSHIDA_URL" ]; then echo "ERROR: SUSHIDA_URL not set" >&2; exit 1; fi
case "$SUSHIDA_URL" in
    https://sushida.net|https://sushida.net/|https://sushida.net/*) ;;
    *) echo "ERROR: Invalid or disallowed URL: $SUSHIDA_URL" >&2; exit 1 ;;
esac
case "$INTERVAL" in
    ''|*[!0-9]*)
        echo "ERROR: NETWORK_CHECK_INTERVAL_SECONDS must be a positive integer: $INTERVAL" >&2
        exit 1 ;;
esac
if [ "$INTERVAL" -lt "$MIN_INTERVAL" ]; then
    echo "ERROR: NETWORK_CHECK_INTERVAL_SECONDS=$INTERVAL is below minimum $MIN_INTERVAL" >&2; exit 1
fi
if [ "$INTERVAL" -gt "$MAX_INTERVAL" ]; then
    echo "ERROR: NETWORK_CHECK_INTERVAL_SECONDS=$INTERVAL exceeds maximum $MAX_INTERVAL" >&2; exit 1
fi
case "$MAX_ITER" in
    ''|*[!0-9]*) echo "ERROR: Invalid SUSHIDA_OS_MAX_ITERATIONS: $MAX_ITER" >&2; exit 1 ;;
esac

for cmd in nmcli systemctl id stat grep kill sleep python3 readlink; do
    if ! command -v "$cmd" > /dev/null 2>&1; then
        echo "ERROR: Required command not found: $cmd" >&2; exit 1
    fi
done
if [ ! -x "$KIOSK_SIGNAL" ]; then
    echo "ERROR: Kiosk signal helper not found or not executable: $KIOSK_SIGNAL" >&2
    exit 1
fi

route_model() {
    PYTHONPATH="$RUNTIME_LIB" PYTHONDONTWRITEBYTECODE=1 \
        python3 -m sushida_os.runtime.routes "$@" 2>/dev/null
}

# Read/update the runtime-state.json protocol (the authoritative route
# record since BL-01).  Reads fail closed: any missing, malformed, or
# unknown-versioned state reads as failure and the caller does not signal.
runtime_state() {
    PYTHONPATH="$RUNTIME_LIB" PYTHONDONTWRITEBYTECODE=1 \
        python3 -m sushida_os.runtime.runtime_state \
        --directory "$RUNTIME_DIR" "$@" 2>/dev/null
}

desired_route() {
    # Gather observations here; the route decision itself lives in the pure
    # sushida_os.runtime.routes model.  A model failure fails closed to the
    # offline route without signalling anything.
    local status state connectivity route
    local model_args=()
    if [ "$FORCE_OFFLINE" = true ]; then
        model_args+=(--force-offline)
    else
        if [ "$(runtime_state --print time-sync-required)" = "1" ]; then
            if timedatectl show -p NTPSynchronized --value 2>/dev/null | grep -qx yes; then
                # Clearing the hold is a state write; if it fails the hold
                # stays in place (fail closed) and is retried next cycle.
                runtime_state --clear-time-sync || model_args+=(--time-sync-pending)
            else
                model_args+=(--time-sync-pending)
            fi
        fi
        # Fall through to normal NetworkManager-based observation after the
        # time-sync marker has been cleared or was never present.
        if [ ${#model_args[@]} -eq 0 ]; then
            if status=$(LC_ALL=C nmcli -t -f STATE,CONNECTIVITY general 2>/dev/null); then
                state="${status%%:*}"
                connectivity="${status#*:}"
                model_args+=(--nm-ok --nm-state "$state" --nm-connectivity "$connectivity")
            fi
            if systemctl -q is-active sushida-wifi-setup.service 2>/dev/null; then
                model_args+=(--setup-active)
            fi
        fi
    fi
    route=$(route_model "${model_args[@]}") || route=""
    case "$route" in online|setup|offline) ;; *) route=offline ;; esac
    printf '%s\n' "$route"
}

read_active_route() {
    local route
    route=$(runtime_state --print active-route) || return 1
    case "$route" in online|setup|offline) printf '%s\n' "$route" ;; *) return 1 ;; esac
}

restart_kiosk() {
    # The MainPID/UID/cgroup validation chain lives in the shared helper;
    # only the fixed reason token is passed.
    "$KIOSK_SIGNAL" --reason route-mismatch
}

iteration=0
while true; do
    if [ "$MAX_ITER" -gt 0 ] && [ "$iteration" -ge "$MAX_ITER" ]; then break; fi
    iteration=$((iteration + 1))
    # Mirror the Wi-Fi backend's content-free in-progress marker into the
    # state protocol (best effort; the marker itself stays authoritative).
    connection_in_progress=0
    [ ! -f "$WIFI_CONNECTION_MARKER" ] || connection_in_progress=1
    runtime_state --set-connection-in-progress "$connection_in_progress" || true
    wanted=$(desired_route)
    if active=$(read_active_route) && [ "$active" != "$wanted" ]; then
        restart_kiosk || true
    fi
    sleep "$INTERVAL"
done
