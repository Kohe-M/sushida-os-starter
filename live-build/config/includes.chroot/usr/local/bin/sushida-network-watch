#!/usr/bin/env bash
# Restart the managed kiosk session when its selected route no longer matches
# NetworkManager. Disconnected state selects the constrained local setup UI.
set -euo pipefail

readonly PROD_CONFIG="/etc/sushida-os/config.env"
readonly PROD_RUNTIME="/run/sushida-os"
readonly MIN_INTERVAL=30
readonly MAX_INTERVAL=3600

CONFIG_FILE="${SUSHIDA_OS_CONFIG:-$PROD_CONFIG}"
RUNTIME_DIR="${SUSHIDA_OS_RUNTIME:-$PROD_RUNTIME}"
MAX_ITER="${SUSHIDA_OS_MAX_ITERATIONS:-0}"
TEST_CGROUP_FILE="${SUSHIDA_OS_TEST_CGROUP_FILE:-}"
FORCE_OFFLINE=false

if [ "$CONFIG_FILE" != "$PROD_CONFIG" ] && [ "${SUSHIDA_OS_TEST_MODE:-0}" != "1" ]; then
    echo "ERROR: CONFIG_FILE override requires SUSHIDA_OS_TEST_MODE=1" >&2; exit 1
fi
if [ "$RUNTIME_DIR" != "$PROD_RUNTIME" ] && [ "${SUSHIDA_OS_TEST_MODE:-0}" != "1" ]; then
    echo "ERROR: RUNTIME_DIR override requires SUSHIDA_OS_TEST_MODE=1" >&2; exit 1
fi
if [ "$MAX_ITER" != "0" ] && [ "${SUSHIDA_OS_TEST_MODE:-0}" != "1" ]; then
    echo "ERROR: SUSHIDA_OS_MAX_ITERATIONS override requires SUSHIDA_OS_TEST_MODE=1" >&2; exit 1
fi
if [ -n "$TEST_CGROUP_FILE" ] && [ "${SUSHIDA_OS_TEST_MODE:-0}" != "1" ]; then
    echo "ERROR: SUSHIDA_OS_TEST_CGROUP_FILE requires SUSHIDA_OS_TEST_MODE=1" >&2; exit 1
fi
case "${SUSHIDA_QEMU_FORCE_OFFLINE:-0}" in
    0) ;;
    1)
        if [ "${WLR_RENDERER:-}" != pixman ] || \
           [ "${WLR_RENDERER_ALLOW_SOFTWARE:-0}" != 1 ]; then
            echo "ERROR: QEMU force-offline requires all QEMU renderer markers" >&2
            exit 1
        fi
        FORCE_OFFLINE=true ;;
    *) echo "ERROR: Invalid SUSHIDA_QEMU_FORCE_OFFLINE value" >&2; exit 1 ;;
esac
readonly ACTIVE_ROUTE_FILE="$RUNTIME_DIR/active-route"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "ERROR: Config file not found: $CONFIG_FILE" >&2; exit 1
fi
SUSHIDA_URL=""; INTERVAL=30; seen_url=false; seen_interval=false
while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [ -z "$line" ] || [[ "$line" == "#"* ]]; then continue; fi
    if [[ "$line" != *"="* ]]; then
        echo "ERROR: Invalid config line (missing '='): $line" >&2; exit 1
    fi
    key="${line%%=*}"; value="${line#*=}"
    case "$key" in
        SUSHIDA_URL)
            if $seen_url; then echo "ERROR: Duplicate SUSHIDA_URL" >&2; exit 1; fi
            seen_url=true; SUSHIDA_URL="$value" ;;
        NETWORK_CHECK_INTERVAL_SECONDS)
            if $seen_interval; then
                echo "ERROR: Duplicate NETWORK_CHECK_INTERVAL_SECONDS" >&2; exit 1
            fi
            seen_interval=true; INTERVAL="$value" ;;
        NETWORK_SETUP_GRACE_SECONDS) ;;
        *) echo "ERROR: Unknown config key: $key" >&2; exit 1 ;;
    esac
done < "$CONFIG_FILE"

if [ -z "$SUSHIDA_URL" ]; then echo "ERROR: SUSHIDA_URL not set" >&2; exit 1; fi
case "$SUSHIDA_URL" in
    https://sushida.net|https://sushida.net/|https://sushida.net/*) ;;
    *) echo "ERROR: Invalid or disallowed URL: $SUSHIDA_URL" >&2; exit 1 ;;
esac
case "$INTERVAL" in
    ''|*[!0-9]*)
        echo "ERROR: NETWORK_CHECK_INTERVAL_SECONDS must be a positive integer: $INTERVAL" >&2
        exit 1 ;;
esac
if [ "$INTERVAL" -lt "$MIN_INTERVAL" ]; then
    echo "ERROR: NETWORK_CHECK_INTERVAL_SECONDS=$INTERVAL is below minimum $MIN_INTERVAL" >&2; exit 1
fi
if [ "$INTERVAL" -gt "$MAX_INTERVAL" ]; then
    echo "ERROR: NETWORK_CHECK_INTERVAL_SECONDS=$INTERVAL exceeds maximum $MAX_INTERVAL" >&2; exit 1
fi
case "$MAX_ITER" in
    ''|*[!0-9]*) echo "ERROR: Invalid SUSHIDA_OS_MAX_ITERATIONS: $MAX_ITER" >&2; exit 1 ;;
esac

for cmd in nmcli systemctl id stat grep kill sleep; do
    if ! command -v "$cmd" > /dev/null 2>&1; then
        echo "ERROR: Required command not found: $cmd" >&2; exit 1
    fi
done

desired_route() {
    local status state connectivity
    if [ "$FORCE_OFFLINE" = true ]; then
        printf '%s\n' offline
    elif status=$(LC_ALL=C nmcli -t -f STATE,CONNECTIVITY general 2>/dev/null); then
        state="${status%%:*}"
        connectivity="${status#*:}"
        if [ "$state" = connected ] && [ "$connectivity" = full ]; then
            printf '%s\n' online
        elif systemctl -q is-active sushida-wifi-setup.service 2>/dev/null; then
            printf '%s\n' setup
        else
            printf '%s\n' offline
        fi
    elif systemctl -q is-active sushida-wifi-setup.service 2>/dev/null; then
        printf '%s\n' setup
    else
        printf '%s\n' offline
    fi
}

read_active_route() {
    [ -f "$ACTIVE_ROUTE_FILE" ] || return 1
    local route
    IFS= read -r route < "$ACTIVE_ROUTE_FILE" || return 1
    case "$route" in online|setup|offline) printf '%s\n' "$route" ;; *) return 1 ;; esac
}

restart_kiosk() {
    systemctl -q is-active sushida-kiosk.service 2>/dev/null || return 1
    local pid my_uid pid_uid cgroup_file
    pid=$(systemctl show --property MainPID --value sushida-kiosk.service 2>/dev/null) || return 1
    case "$pid" in ''|*[!0-9]*) return 1 ;; esac
    [ "$pid" -gt 1 ] || return 1
    [ -d "/proc/$pid" ] || return 1
    my_uid=$(id -u) || return 1
    pid_uid=$(stat -c '%u' "/proc/$pid" 2>/dev/null) || return 1
    [ "$pid_uid" = "$my_uid" ] || return 1
    cgroup_file="/proc/$pid/cgroup"
    if [ -n "$TEST_CGROUP_FILE" ]; then cgroup_file="$TEST_CGROUP_FILE"; fi
    [ -f "$cgroup_file" ] || return 1
    grep -Eq '(^|/)sushida-kiosk\.service($|/)' "$cgroup_file" || return 1
    kill -TERM -- "$pid"
}

iteration=0
while true; do
    if [ "$MAX_ITER" -gt 0 ] && [ "$iteration" -ge "$MAX_ITER" ]; then break; fi
    iteration=$((iteration + 1))
    wanted=$(desired_route)
    if active=$(read_active_route) && [ "$active" != "$wanted" ]; then
        restart_kiosk || true
    fi
    sleep "$INTERVAL"
done
