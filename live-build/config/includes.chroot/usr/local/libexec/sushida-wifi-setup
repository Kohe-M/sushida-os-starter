#!/usr/bin/env python3
"""Loopback-only Wi-Fi setup UI with narrowly scoped persistent state.

Thin service entrypoint: the implementation lives in the sushida_os.wifi
package (types/storage/nmcli/coordinator/restore/web).  This wrapper only
wires the dependencies, starts the worker and restore threads, and serves
HTTP.  Every backend name is re-exported so the systemd ExecStart path and
the characterization-test surface stay unchanged.  An import failure here
raises a plain ImportError that carries no credential material.
"""

from __future__ import annotations

import threading
from http.server import HTTPServer

from sushida_os.wifi.coordinator import (
    _connect_worker,
    _publish_result,
    _reset_failure,
    _take_pending,
    connect_status,
    consume_failure,
    enqueue_interactive,
    interactive_pending,
    queue_connection,
    reset_succeeded,
    restore_cancelled,
    start_queued_connection,
)
from sushida_os.wifi.restore import restore_saved_connection
from sushida_os.wifi.web import (
    CONNECTING_SCRIPT,
    HOST,
    MAX_REQUEST_BYTES,
    ORIGIN,
    PORT,
    REQUEST_READ_TIMEOUT_SECONDS,
    SetupHandler,
    render_connecting_page,
    render_page,
    script_csp_hash,
)
from sushida_os.wifi.nmcli import (
    COMMAND_TIMEOUT_SECONDS,
    CONNECT_LOCK,
    NMCLI,
    _cleanup_profile,
    _connect_wifi,
    _delete_old_profile,
    _failure_message,
    _log_stage,
    _profile_exists,
    _run_nmcli_stage,
    _split_escaped,
    _temporary_fd,
    _verify_autoconnect,
    _wifi_reason,
    classify_security,
    connect_wifi,
    managed_wifi_active,
    network_connected,
    nmcli_path,
    run_nmcli,
    scan_networks,
)
from sushida_os.wifi.storage import (
    CSRF_TOKEN_FILE,
    FILESYSTEM_LABEL,
    MAX_CONFIG_BYTES,
    STORAGE_STATUS,
    config_dir,
    config_file,
    config_mount,
    csrf_token,
    csrf_token_file,
    load_credentials,
    persist_credentials,
    persistent_storage_ready,
    storage_status,
)
from sushida_os.wifi.types import (
    CONNECTION_NAME,
    CONNECT_FAILED,
    CONNECT_IDLE,
    CONNECT_SUCCEEDED,
    CONNECT_WORKING,
    _validate_password_shape,
    _validate_ssid,
    validate_credentials,
)


def main() -> None:
    csrf_token()
    threading.Thread(target=_connect_worker, daemon=True).start()
    threading.Thread(target=restore_saved_connection, daemon=True).start()
    server = HTTPServer((HOST, PORT), SetupHandler)
    server.serve_forever()


if __name__ == "__main__":
    main()
