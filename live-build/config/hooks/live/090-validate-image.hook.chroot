#!/usr/bin/env bash
# Fail the live-build chroot stage if the production image violates a required
# account, package, policy, service, permission, or volatile-state invariant.
set -euo pipefail

fail() {
    echo "ERROR: image validation: $*" >&2
    exit 1
}

require_command() {
    command -v "$1" > /dev/null 2>&1 || fail "missing command: $1"
}

require_package() {
    local status
    status="$(dpkg-query -W -f='${db:Status-Abbrev}' "$1" 2>/dev/null || true)"
    [ "${status:0:2}" = "ii" ] || fail "required package is not installed: $1"
}

reject_package() {
    if dpkg-query -W -f='${Status}' "$1" 2>/dev/null | grep -q 'ok installed'; then
        fail "prohibited package is installed: $1"
    fi
}

require_file() {
    [ -f "$1" ] || fail "missing file: $1"
}

require_executable() {
    require_file "$1"
    [ -x "$1" ] || fail "file is not executable: $1"
    [ "$(stat -c '%U:%G:%a' "$1")" = "root:root:755" ] || \
        fail "unsafe owner or mode for $1: $(stat -c '%U:%G:%a' "$1")"
}

for cmd in dpkg-query getent id stat systemctl systemd-analyze python3 setupcon; do
    require_command "$cmd"
done

# Account boundary.
getent passwd kiosk > /dev/null || fail "kiosk account is missing"
IFS=: read -r _name _password uid gid _gecos home shell < <(getent passwd kiosk)
[ "$uid" -ne 0 ] || fail "kiosk UID must not be zero"
[ "$gid" -ne 0 ] || fail "kiosk primary GID must not be zero"
[ "$home" = "/nonexistent" ] || fail "unexpected kiosk home: $home"
[ "$shell" = "/usr/sbin/nologin" ] || fail "unexpected kiosk shell: $shell"
shadow_password="$(getent shadow kiosk | cut -d: -f2)"
case "$shadow_password" in !*|\**) ;; *) fail "kiosk password is not locked" ;; esac
for group in audio video render input; do
    id -nG kiosk | tr ' ' '\n' | grep -qx "$group" || \
        fail "kiosk is missing required group: $group"
done
for group in root sudo adm wheel disk shadow; do
    if id -nG kiosk | tr ' ' '\n' | grep -qx "$group"; then
        fail "kiosk belongs to prohibited group: $group"
    fi
done

getent passwd wifi-setup > /dev/null || fail "wifi-setup account is missing"
IFS=: read -r _name _password setup_uid setup_gid _gecos setup_home setup_shell < <(getent passwd wifi-setup)
[ "$setup_uid" -ne 0 ] || fail "wifi-setup UID must not be zero"
[ "$setup_gid" -ne 0 ] || fail "wifi-setup primary GID must not be zero"
[ "$setup_home" = "/nonexistent" ] || fail "unexpected wifi-setup home: $setup_home"
[ "$setup_shell" = "/usr/sbin/nologin" ] || fail "unexpected wifi-setup shell: $setup_shell"
[ "$(id -nG wifi-setup)" = "wifi-setup" ] || fail "wifi-setup has supplementary groups"
setup_shadow_password="$(getent shadow wifi-setup | cut -d: -f2)"
case "$setup_shadow_password" in !*|\**) ;; *) fail "wifi-setup password is not locked" ;; esac

# Required production packages.
for package in \
    linux-image-amd64 live-boot live-config systemd-sysv cage chromium \
    network-manager wpasupplicant polkitd pipewire pipewire-pulse wireplumber \
    libspa-0.2-modules dbus-user-session libgl1-mesa-dri mesa-va-drivers \
    libegl1 libgles2 libgbm1 libdrm2 libwayland-client0 \
    libwayland-server0 python3-minimal python3 pciutils \
    systemd-timesyncd; do
    require_package "$package"
done

python3 -c 'import hashlib, hmac, html, http.server, json, secrets, threading, urllib.parse' || \
    fail "Wi-Fi setup Python standard library is incomplete"

# Wi-Fi backend package: every module must be present with safe modes and
# importable.  The image ships source-only Python: import verification runs
# with PYTHONDONTWRITEBYTECODE=1 and any leftover bytecode cache fails the
# build, so the squashfs never contains .pyc files for these modules.
backend_package=/usr/lib/python3/dist-packages/sushida_os
for module in \
    "$backend_package/__init__.py" \
    "$backend_package/wifi/__init__.py" \
    "$backend_package/wifi/types.py" \
    "$backend_package/wifi/storage.py" \
    "$backend_package/wifi/nmcli.py" \
    "$backend_package/wifi/coordinator.py" \
    "$backend_package/wifi/restore.py" \
    "$backend_package/wifi/web.py" \
    "$backend_package/runtime/__init__.py" \
    "$backend_package/runtime/routes.py" \
    "$backend_package/runtime/runtime_state.py" \
    "$backend_package/runtime/kiosk_signal.py"; do
    require_file "$module"
    [ "$(stat -c '%U:%G:%a' "$module")" = "root:root:644" ] || \
        fail "unsafe owner or mode for $module: $(stat -c '%U:%G:%a' "$module")"
done
PYTHONDONTWRITEBYTECODE=1 python3 - <<'PYEOF' || fail "Wi-Fi backend package does not import"
import sushida_os.wifi.coordinator
import sushida_os.wifi.restore
import sushida_os.wifi.web
import sushida_os.runtime.routes
import sushida_os.runtime.runtime_state
import sushida_os.runtime.kiosk_signal
PYEOF
if find "$backend_package" -name '__pycache__' -o -name '*.pyc' | grep -q .; then
    fail "Wi-Fi backend package must ship without bytecode caches"
fi

# Production image must not expose a shell, desktop, display manager, remote
# administration service, proprietary NVIDIA stack, or persistence tooling.
for package in \
    openssh-server dropbear telnetd inetutils-telnetd sudo \
    xterm gnome-terminal konsole xfce4-terminal mate-terminal lxterminal \
    nautilus dolphin thunar pcmanfm \
    gdm3 sddm lightdm xdm slim lxdm \
    xserver-xorg xserver-xorg-core xorg \
    task-gnome-desktop task-kde-desktop task-xfce-desktop \
    nvidia-driver nvidia-kernel-dkms nvidia-settings; do
    reject_package "$package"
done

# Installed scripts and units.
for file in \
    /usr/local/bin/sushida-launch \
    /usr/local/bin/sushida-network-watch \
    /usr/local/bin/sushida-navigation-watch \
    /usr/local/bin/sushida-diagnostics \
    /usr/local/libexec/sushida-session \
    /usr/local/libexec/sushida-config-prepare \
    /usr/local/libexec/sushida-wifi-setup \
    /usr/local/libexec/sushida-kiosk-signal; do
    require_executable "$file"
done

# Physical JIS keyboard layout is configured both for console-setup and the
# Wayland session inherited by Cage/Chromium.
keyboard=/etc/default/keyboard
require_file "$keyboard"
grep -qx 'XKBMODEL="pc105"' "$keyboard" || fail "unexpected XKBMODEL"
grep -qx 'XKBLAYOUT="jp"' "$keyboard" || fail "unexpected XKBLAYOUT"
grep -qx 'XKBVARIANT="106"' "$keyboard" || fail "unexpected XKBVARIANT"
grep -qx 'XKBOPTIONS=""' "$keyboard" || fail "unexpected XKBOPTIONS"
grep -qx 'BACKSPACE="guess"' "$keyboard" || fail "unexpected BACKSPACE"
cache_file="$(
    find /etc/console-setup -maxdepth 1 -type f \
        -name 'cached_*.kmap.gz' -print -quit
)"
[ -n "$cache_file" ] || fail "JIS console keymap cache is missing"
[ -x /etc/console-setup/cached_setup_keyboard.sh ] || \
    fail "cached keyboard setup script is missing"
grep -qx 'Environment=XKB_DEFAULT_MODEL=pc105' \
    /etc/systemd/system/sushida-kiosk.service || fail "kiosk XKB model is not pc105"
grep -qx 'Environment=XKB_DEFAULT_LAYOUT=jp' \
    /etc/systemd/system/sushida-kiosk.service || fail "kiosk XKB layout is not jp"
grep -qx 'Environment=XKB_DEFAULT_VARIANT=106' \
    /etc/systemd/system/sushida-kiosk.service || fail "kiosk XKB variant is not 106"
grep -qx 'Environment=XKB_DEFAULT_OPTIONS=' \
    /etc/systemd/system/sushida-kiosk.service || fail "kiosk XKB options are not empty"
logind=/etc/systemd/logind.conf.d/90-sushida-kiosk.conf
require_file "$logind"
grep -qx 'NAutoVTs=0' "$logind" || fail "NAutoVTs is not disabled"
grep -qx 'ReserveVT=0' "$logind" || fail "ReserveVT is not disabled"
grep -qx 'HandlePowerKey=poweroff' "$logind" || fail "power key action is not poweroff"
grep -qx 'HandlePowerKeyLongPress=ignore' "$logind" || fail "long power press is not ignored"
grep -qx 'PowerKeyIgnoreInhibited=yes' "$logind" || fail "power-key inhibitor policy is unsafe"
if grep -R -n -E 'acpid|systemctl[[:space:]]+enable[[:space:]]+poweroff\.target' \
    /etc/systemd/system /etc/systemd/logind.conf.d /etc/systemd/system.conf.d \
    > /dev/null 2>&1; then
    fail "custom power event daemon or enabled poweroff target is present"
fi
for unit in sushida-kiosk.service sushida-network-watch.service \
    sushida-navigation-watch.service \
    sushida-config-prepare.service sushida-wifi-setup.service \
    'var-lib-sushida\x2dconfig.mount'; do
    require_file "/etc/systemd/system/$unit"
    systemctl is-enabled "$unit" > /dev/null 2>&1 || fail "$unit is not enabled"
done
systemctl is-enabled systemd-timesyncd.service > /dev/null 2>&1 || \
    fail "systemd-timesyncd.service is not enabled"
for unit in getty@.service autovt@.service serial-getty@.service \
    console-getty.service container-getty@.service ctrl-alt-del.target \
    apt-daily.timer apt-daily-upgrade.timer apt-daily.service \
    apt-daily-upgrade.service; do
    [ "$(systemctl is-enabled "$unit" 2>/dev/null || true)" = "masked" ] || \
        fail "$unit is not masked"
done
systemd-analyze verify \
    /etc/systemd/system/sushida-kiosk.service \
    /etc/systemd/system/sushida-network-watch.service \
    /etc/systemd/system/sushida-navigation-watch.service \
    /etc/systemd/system/sushida-config-prepare.service \
    /etc/systemd/system/sushida-wifi-setup.service \
    '/etc/systemd/system/var-lib-sushida\x2dconfig.mount'

polkit_rule=/etc/polkit-1/rules.d/60-sushida-wifi-setup.rules
require_file "$polkit_rule"
[ "$(stat -c '%U:%G:%a' "$polkit_rule")" = "root:root:644" ] || \
    fail "unsafe owner or mode for Wi-Fi polkit rule"

# Chromium policy: syntax, types, exact security values, and minimal origins.
policy=/etc/chromium/policies/managed/sushida-os.json
require_file "$policy"
python3 - "$policy" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path, encoding="utf-8") as stream:
    policy = json.load(stream)

expected = {
    "DeveloperToolsAvailability": 2,
    "BrowserGuestModeEnabled": False,
    "IncognitoModeAvailability": 1,
    "BrowserSignin": 0,
    "PasswordManagerEnabled": False,
    "AutofillAddressEnabled": False,
    "AutofillCreditCardEnabled": False,
    "PrintingEnabled": False,
    "DownloadRestrictions": 3,
    "AllowFileSelectionDialogs": False,
}
for key, value in expected.items():
    if policy.get(key) != value or type(policy.get(key)) is not type(value):
        raise SystemExit(f"invalid Chromium policy {key}")
if policy.get("URLBlocklist") != [
    "*", "view-source:*", "chrome://*",
    "chrome-untrusted://*", "devtools://*",
]:
    raise SystemExit("invalid URLBlocklist")
if policy.get("URLAllowlist") != [
    "https://.sushida.net:443",
    "file:///usr/share/sushida-os/offline.html",
    "http://127.0.0.1:8787",
]:
    raise SystemExit("invalid URLAllowlist")
PY

# Volatile runtime and log configuration.
tmpfiles=/usr/lib/tmpfiles.d/sushida-os.conf
journal=/etc/systemd/journald.conf.d/90-sushida-os.conf
require_file "$tmpfiles"
require_file "$journal"
for path in home chromium cache tmp downloads xdg-runtime; do
    grep -Eq "^d[[:space:]]+/run/sushida-os/${path}[[:space:]]+0700[[:space:]]+kiosk[[:space:]]+kiosk" "$tmpfiles" || \
        fail "missing volatile runtime path: $path"
done
grep -Eq '^d[[:space:]]+/run/sushida-os[[:space:]]+0750[[:space:]]+kiosk[[:space:]]+kiosk' "$tmpfiles" || \
    fail "missing volatile runtime parent"
grep -qx 'Storage=volatile' "$journal" || fail "journald is not volatile"
[ ! -e /persistence.conf ] || fail "persistence.conf must not be present"

# Optional embedded Wi-Fi credentials must remain root-only.
wifi=/etc/NetworkManager/system-connections/sushida-os-wifi.nmconnection
if [ -e "$wifi" ]; then
    if [ ! -f "$wifi" ] || [ -L "$wifi" ]; then
        fail "Wi-Fi path is not a regular file"
    fi
    [ "$(stat -c '%U:%G:%a' "$wifi")" = "root:root:600" ] || \
        fail "unsafe Wi-Fi owner or mode"
fi

# Reject unresolved markers in installed security-critical files.  Split the
# patterns in source so the validator does not flag its own implementation.
if grep -R -n -E 'TO''DO|FIX''ME|IMPLEMENT[[:space:]]+ME|REPLACE_WITH_' \
    /usr/local/bin/sushida-launch \
    /usr/local/bin/sushida-network-watch \
    /usr/local/bin/sushida-navigation-watch \
    /usr/local/bin/sushida-diagnostics \
    /usr/local/libexec/sushida-session \
    /usr/local/libexec/sushida-config-prepare \
    /usr/local/libexec/sushida-wifi-setup \
    /etc/systemd/system/sushida-kiosk.service \
    /etc/systemd/system/sushida-network-watch.service \
    /etc/systemd/system/sushida-navigation-watch.service \
    /etc/systemd/system/sushida-config-prepare.service \
    /etc/systemd/system/sushida-wifi-setup.service \
    /etc/chromium/policies/managed/sushida-os.json \
    /etc/sushida-os/config.env; then
    fail "unresolved marker in production configuration"
fi

echo "Image validation passed."
