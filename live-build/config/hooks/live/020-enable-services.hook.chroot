#!/usr/bin/env bash
#
# live-build chroot hook -- enable production systemd services.
# Runs inside the target chroot during image build, NOT on the host.
set -euo pipefail

systemctl enable sushida-kiosk.service
systemctl enable sushida-network-watch.service
systemctl enable sushida-navigation-watch.service
systemctl enable 'var-lib-sushida\x2dconfig.mount'
systemctl enable sushida-config-prepare.service
systemctl enable sushida-wifi-setup.service
systemctl enable systemd-timesyncd.service
