.venv/

# Test output
coverage.xml
htmlcov/
.junit/
test-results/

# Editors and OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# live-build generated state if a command is run from the repository root
.binary/
.chroot/
.cache/
config/bootstrap
config/chroot
config/common
config/source
binary/
chroot/
*.hybrid.iso
*.iso
