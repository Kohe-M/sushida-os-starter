{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sushida.os/contracts/schema/release-contract.schema.json",
  "title": "Sushi-da OS release contract",
  "description": "Expected artifacts, ISO paths, packages, and services in a release build.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifacts",
    "required_iso_paths",
    "source_image_mappings",
    "required_packages",
    "required_services",
    "metadata"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "required", "checksum", "publish", "clean", "verify"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "allOf": [
              {"not": {"pattern": "[/\\\\]"}},
              {"not": {"pattern": "(^|/)\\.\\.(/|$)"}},
              {"not": {"pattern": "[\\r\\n\\t ]"}},
              {"not": {"pattern": "[.]{2}$"}},
              {"not": {"pattern": "^[.]$"}}
            ]
          },
          "required": { "type": "boolean" },
          "checksum": { "type": "boolean" },
          "publish": { "type": "boolean" },
          "clean": { "type": "boolean" },
          "verify": { "type": "boolean" }
        }
      },
      "uniqueItems": true
    },
    "required_iso_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "region", "file_type", "required", "security_critical"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 2,
            "allOf": [
              {"pattern": "^/"},
              {"not": {"pattern": "(^|/)\\.\\.(/|$)"}},
              {"not": {"pattern": "[\\r\\n\\t ]"}}
            ]
          },
          "path_pattern": { "type": "string" },
          "match_type": { "type": "string", "enum": ["literal", "regex"] },
          "region": { "type": "string", "enum": ["iso-root", "squashfs"] },
          "file_type": { "type": "string" },
          "required": { "type": "boolean" },
          "security_critical": { "type": "boolean" }
        },
        "allOf": [
          {
            "if": {
              "properties": { "match_type": { "const": "regex" } },
              "required": ["match_type"]
            },
            "then": { "required": ["path_pattern"] }
          },
          {
            "if": { "required": ["path_pattern"] },
            "then": {
              "properties": { "match_type": { "const": "regex" } },
              "required": ["match_type"]
            }
          }
        ]
      },
      "uniqueItems": true
    },
    "source_image_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source", "image_path", "region", "file_type",
          "mode", "owner", "group", "comparison",
          "required", "security_critical",
          "current_verification", "planned_for_full_verification"
        ],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1,
            "allOf": [
              {"not": {"pattern": "^/"}},
              {"not": {"pattern": "(^|/)\\.\\.(/|$)"}},
              {"not": {"pattern": "[\\r\\n\\t ]"}},
              {"not": {"pattern": "^[.]$"}}
            ]
          },
          "image_path": {
            "type": "string",
            "minLength": 2,
            "allOf": [
              {"pattern": "^/"},
              {"not": {"pattern": "(^|/)\\.\\.(/|$)"}},
              {"not": {"pattern": "[\\r\\n\\t ]"}}
            ]
          },
          "region": { "type": "string", "enum": ["iso-root", "squashfs"] },
          "file_type": { "type": "string" },
          "mode": { "type": "string", "pattern": "^[0-7]{4}$" },
          "owner": { "type": "string" },
          "group": { "type": "string" },
          "comparison": { "type": "string", "enum": ["cmp", "presence", "size", "sha256"] },
          "required": { "type": "boolean" },
          "security_critical": { "type": "boolean" },
          "current_verification": {
            "type": "string",
            "enum": ["none", "presence", "exact"]
          },
          "planned_for_full_verification": { "type": "boolean" }
        }
      },
      "uniqueItems": true
    },
    "required_packages": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "required_services": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "state"],
        "properties": {
          "name": { "type": "string", "pattern": "\\.(service|mount|target|timer)$" },
          "state": { "type": "string", "enum": ["enabled", "masked", "disabled"] }
        }
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_fields", "static_values", "formats"],
      "properties": {
        "required_fields": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "static_values": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "formats": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
